# Copy to .env and fill in values:
#   cp dotfiles/.env.example .env
#
# Then: dotctl generate

GITHUB_TOKEN=           # gh auth token  or  GitHub Settings > PATs
SMITHERY_KEY=           # smithery.ai dashboard
SMITHERY_YT_PROFILE=    # smithery.ai profile name
SUPABASE_ACCESS_TOKEN=  # supabase.com/dashboard/account/tokens
SUPABASE_PROJECT_REF=   # supabase project settings > General
STITCH_API_KEY=         # Google AI Studio
