{
  "$schema_version": 1,
  "servers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "youtube-download": {
      "command": "npx",
      "args": ["-y", "@smithery/cli@latest", "run", "@daniellopez-2/youtube-download", "--key", "$SMITHERY_KEY", "--profile", "$SMITHERY_YT_PROFILE"]
    },
    "linear-server": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "tosspayments-integration-guide": {
      "command": "npx",
      "args": ["-y", "@tosspayments/integration-guide-mcp@latest"]
    },
    "stitch": {
      "type": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "$STITCH_API_KEY"
      }
    }
  }
}
