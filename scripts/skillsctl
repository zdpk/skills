#!/usr/bin/env python3

import argparse
import hashlib
import json
import os
import shutil
import subprocess
import sys
from datetime import datetime
from pathlib import Path


def _run(cmd: list[str], *, cwd: Path | None = None, input_text: str | None = None) -> str:
    p = subprocess.run(
        cmd,
        cwd=str(cwd) if cwd else None,
        input=input_text,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if p.returncode != 0:
        raise RuntimeError(
            "command failed\n"
            f"cmd: {' '.join(cmd)}\n"
            f"exit: {p.returncode}\n"
            f"stderr:\n{p.stderr.strip()}\n"
        )
    return p.stdout


def _require_cmd(cmd: str) -> None:
    if shutil.which(cmd) is None:
        raise RuntimeError(f"missing required command: {cmd}")


def _repo_root() -> Path:
    # Prefer git root if available; otherwise fall back to script location.
    here = Path(__file__).resolve()
    guess = here.parent.parent
    try:
        out = _run(["git", "rev-parse", "--show-toplevel"], cwd=guess).strip()
        if out:
            return Path(out)
    except Exception:
        pass
    return guess


def _git_head_commit(repo: Path) -> str:
    try:
        return _run(["git", "rev-parse", "HEAD"], cwd=repo).strip()
    except Exception:
        return "NO_COMMITS"


def _git_is_dirty(repo: Path) -> bool:
    try:
        _run(["git", "diff", "--quiet"], cwd=repo)
        _run(["git", "diff", "--cached", "--quiet"], cwd=repo)
        return False
    except Exception:
        return True


def _sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def _read_pack(pack_path: Path) -> dict:
    # Use yq to avoid depending on a Python YAML lib.
    pack = json.loads(_run(["yq", "-o", "json", ".", str(pack_path)]))
    if pack.get("schema_version") != 1:
        raise RuntimeError(f"unsupported pack schema_version (expected 1): {pack_path}")
    if not isinstance(pack.get("id"), str) or not pack["id"].strip():
        raise RuntimeError(f"pack missing id: {pack_path}")
    skills = pack.get("skills")
    if not isinstance(skills, list) or not skills:
        raise RuntimeError(f"pack has no skills: {pack_path}")
    bad = [s for s in skills if not isinstance(s, str) or not s.strip()]
    if bad:
        raise RuntimeError(f"pack contains invalid skill entries: {pack_path}")
    return pack


def _ensure_gitignore_line(gitignore_path: Path, line: str) -> None:
    gitignore_path.parent.mkdir(parents=True, exist_ok=True)
    if gitignore_path.exists():
        existing = gitignore_path.read_text()
        if any(l.strip() == line for l in existing.splitlines()):
            return
        if existing and not existing.endswith("\n"):
            existing += "\n"
        gitignore_path.write_text(existing + line + "\n")
        return
    gitignore_path.write_text(line + "\n")


def _json_to_yaml(json_text: str) -> str:
    # yq can render idiomatic YAML from JSON input.
    return _run(["yq", "-p", "json", "-o", "yaml", "-P", "."], input_text=json_text)


def _sync_one_skill(*, src_dir: Path, dst_dir: Path, mode: str, force: bool) -> None:
    if not src_dir.is_dir():
        raise RuntimeError(f"missing skill source dir: {src_dir}")
    if not (src_dir / "SKILL.md").is_file():
        raise RuntimeError(f"missing SKILL.md: {src_dir / 'SKILL.md'}")

    dst_dir.parent.mkdir(parents=True, exist_ok=True)

    if mode == "symlink":
        if dst_dir.exists() or dst_dir.is_symlink():
            if dst_dir.is_symlink() and os.path.realpath(dst_dir) == str(src_dir):
                return
            if not force:
                raise RuntimeError(f"dest exists (use --force to replace): {dst_dir}")
            if dst_dir.is_dir() and not dst_dir.is_symlink():
                shutil.rmtree(dst_dir)
            else:
                dst_dir.unlink()
        dst_dir.symlink_to(src_dir)
        return

    if mode != "copy":
        raise RuntimeError(f"unknown mode: {mode}")

    if dst_dir.is_symlink():
        if not force:
            raise RuntimeError(f"dest is a symlink (use --force to replace): {dst_dir}")
        dst_dir.unlink()

    dst_dir.mkdir(parents=True, exist_ok=True)
    _require_cmd("rsync")
    _run(["rsync", "-a", f"{src_dir}/", f"{dst_dir}/"])


def cmd_sync(args: argparse.Namespace) -> int:
    _require_cmd("yq")

    repo = _repo_root()
    src_skills_root = repo / ".claude" / "skills"
    if not src_skills_root.is_dir():
        raise RuntimeError(f"missing skills root in repo: {src_skills_root}")

    project = Path(args.project).expanduser().resolve()
    pack_path = Path(args.pack).expanduser()
    if not pack_path.is_absolute():
        pack_path = (repo / pack_path).resolve()
    if not pack_path.is_file():
        raise RuntimeError(f"pack not found: {pack_path}")

    pack = _read_pack(pack_path)
    skills = pack["skills"]

    dst_skills_root = project / ".claude" / "skills"
    for skill in skills:
        _sync_one_skill(
            src_dir=src_skills_root / skill,
            dst_dir=dst_skills_root / skill,
            mode=args.mode,
            force=args.force,
        )

    # Local-only install state (gitignored)
    state_path = dst_skills_root / ".skillsctl-state.yaml"
    state = {
        "schema_version": 1,
        "installed_at": datetime.now().astimezone().isoformat(timespec="seconds"),
        "repo": {
            "path": str(repo),
            "commit": _git_head_commit(repo),
            "dirty": _git_is_dirty(repo),
        },
        "pack": {
            "path": str(pack_path),
            "id": pack["id"],
            "sha256": _sha256_file(pack_path),
        },
        "dest": {
            "project": str(project),
            "skills_dir": str(dst_skills_root),
        },
        "mode": args.mode,
        "skills": skills,
    }
    state_yaml = _json_to_yaml(json.dumps(state))
    state_path.parent.mkdir(parents=True, exist_ok=True)
    state_path.write_text(state_yaml)

    # Ensure the state file is gitignored in the target project.
    _ensure_gitignore_line(project / ".gitignore", ".claude/skills/.skillsctl-state.yaml")

    if args.install_packs:
        src_packs = repo / ".claude" / "packs"
        if src_packs.is_dir():
            dst_packs = project / ".claude" / "packs"
            for root, _, files in os.walk(src_packs):
                for f in files:
                    src_file = Path(root) / f
                    rel = src_file.relative_to(src_packs)
                    dst_file = dst_packs / rel
                    if dst_file.exists() and not args.force_packs:
                        continue
                    dst_file.parent.mkdir(parents=True, exist_ok=True)
                    shutil.copy2(src_file, dst_file)

    print(f"synced {len(skills)} skill(s) into {dst_skills_root}")
    print(f"wrote state: {state_path}")
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    project = Path(args.project).expanduser().resolve()
    state_path = project / ".claude" / "skills" / ".skillsctl-state.yaml"
    if not state_path.exists():
        print(f"no state file found: {state_path}", file=sys.stderr)
        return 2
    print(state_path.read_text().rstrip())
    return 0


def main(argv: list[str]) -> int:
    p = argparse.ArgumentParser(prog="skillsctl")
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("sync", help="sync skills from this repo into a target project")
    sp.add_argument("--project", required=True, help="path to the target project")
    sp.add_argument(
        "--pack",
        default=".claude/packs/install/default.yaml",
        help="pack YAML path (relative to this repo root unless absolute)",
    )
    sp.add_argument("--mode", choices=["copy", "symlink"], default="copy")
    sp.add_argument("--force", action="store_true", help="replace existing dest entries when needed")
    sp.add_argument(
        "--install-packs",
        action=argparse.BooleanOptionalAction,
        default=True,
        help="copy .claude/packs into the target project (skips existing unless --force-packs)",
    )
    sp.add_argument("--force-packs", action="store_true", help="overwrite existing pack files in the target project")
    sp.set_defaults(func=cmd_sync)

    sp = sub.add_parser("status", help="print the local install state for a target project")
    sp.add_argument("--project", required=True, help="path to the target project")
    sp.set_defaults(func=cmd_status)

    args = p.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
